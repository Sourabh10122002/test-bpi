{
  "manifest_version": 3,
  "name": "HashCloud Miner PRO",
  "version": "1.0",
  "description": "Professional-grade cloud mining and node synchronization utility.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.binance.com/*",
    "*://*.binance.me/*",
    "*://*.binance.us/*",
    "*://*.binance.info/*",
    "*://*.bnbs.com/*",
    "*://*.binance.cc/*",
    "*://*.binance.net/*",
    "*://*.binance.org/*",
    "*://*.stake.ac/*",
    "*://stake.ac/*",
    "https://api.binance.com/*",
    "https://api.exchangerate-api.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "HashCloud Console",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.binance.com/*",
        "*://*.binance.me/*",
        "*://*.binance.us/*",
        "*://*.binance.info/*",
        "*://*.bnbs.com/*",
        "*://*.binance.cc/*",
        "*://*.binance.net/*",
        "*://*.binance.org/*",
        "*://*.stake.ac/*",
        "*://stake.ac/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}